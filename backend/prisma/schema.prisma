generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WeatherSearch {
  id                 Int      @id @default(autoincrement())
  city               String
  units              String
  temperature        Float
  weatherDescription String
  searchedAt         DateTime @default(now())

  @@index([city])
}
